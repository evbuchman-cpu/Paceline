# =============================================================================
# PACELINE ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Frontend URL
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Database (Neon PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host.region.aws.neon.tech/database?sslmode=require&channel_binding=require

# -----------------------------------------------------------------------------
# Cloudflare R2 Storage (Images)
# -----------------------------------------------------------------------------
R2_UPLOAD_IMAGE_ACCESS_KEY_ID=your-r2-access-key-id-here
R2_UPLOAD_IMAGE_SECRET_ACCESS_KEY=your-r2-secret-access-key-here
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id-here
R2_UPLOAD_IMAGE_BUCKET_NAME=paceline

# -----------------------------------------------------------------------------
# Cloudflare R2 Storage (PDF Guide Storage - can use same bucket)
# -----------------------------------------------------------------------------
R2_ACCESS_KEY_ID=your-r2-access-key-id-here
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key-here
R2_BUCKET_NAME=paceline
R2_PUBLIC_DOMAIN=pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev

# -----------------------------------------------------------------------------
# Authentication (Better Auth)
# -----------------------------------------------------------------------------
# The canonical URL of your app (used by Better Auth for redirects/cookies)
BETTER_AUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-better-auth-secret-key-here-use-openssl-to-generate

# -----------------------------------------------------------------------------
# Google OAuth (Better Auth)
# -----------------------------------------------------------------------------
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret

# -----------------------------------------------------------------------------
# Payments (Polar.sh)
# -----------------------------------------------------------------------------
# Get from: https://polar.sh/dashboard/settings
POLAR_ACCESS_TOKEN=polar_oat_your-polar-access-token-here
POLAR_SUCCESS_URL=/success?checkout_id={CHECKOUT_ID}
POLAR_WEBHOOK_SECRET=polar_whs_your-webhook-secret-here

# Paceline Product Tiers (One-time purchases)
# Get product IDs from: https://polar.sh/dashboard/products
NEXT_PUBLIC_ESSENTIAL_TIER=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
NEXT_PUBLIC_ESSENTIAL_SLUG=Paceline-Essential
NEXT_PUBLIC_CUSTOM_TIER=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
NEXT_PUBLIC_CUSTOM_SLUG=Paceline-Custom
NEXT_PUBLIC_ULTRA_BUNDLE_TIER=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
NEXT_PUBLIC_ULTRA_BUNDLE_SLUG=Paceline-Ultra-Bundle

# -----------------------------------------------------------------------------
# AI APIs
# -----------------------------------------------------------------------------
# OpenAI API Key (GPT-4)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# Anthropic API Key (Claude)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-your-anthropic-api-key-here

# -----------------------------------------------------------------------------
# Strava OAuth
# -----------------------------------------------------------------------------
# Get from: https://www.strava.com/settings/api
STRAVA_CLIENT_ID=123456
STRAVA_CLIENT_SECRET=your-strava-client-secret-here
STRAVA_REDIRECT_URI=http://localhost:3000/api/strava/callback

# -----------------------------------------------------------------------------
# Email (Resend)
# -----------------------------------------------------------------------------
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_your-resend-api-key-here
RESEND_FROM_EMAIL=onboarding@resend.dev

# -----------------------------------------------------------------------------
# Lead Magnet
# -----------------------------------------------------------------------------
# Public URL for the lead magnet PDF (uploaded to R2)
# Run: npx tsx scripts/upload-lead-magnet.ts to upload and get the URL
LEAD_MAGNET_PDF_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev/lead-magnets/race-day-readiness-checklist.pdf

# -----------------------------------------------------------------------------
# Optional: Analytics (PostHog)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-key-here
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# =============================================================================
# SETUP INSTRUCTIONS
# =============================================================================
#
# 1. Copy this file to .env.local:
#    cp .env.example .env.local
#
# 2. Fill in your actual values (get from services listed above)
#
# 3. Never commit .env.local to git (it's in .gitignore)
#
# 4. For production deployment (Vercel):
#    - Add these variables in Vercel project settings
#    - Update NEXT_PUBLIC_APP_URL to your production domain
#    - Use production API keys (not sandbox/test mode)
#
# =============================================================================
